# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration
# For local development: mongodb://localhost:27017/travelexplore
# For Vercel (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/travelexplore?retryWrites=true&w=majority
MONGODB_URI=your-mongodb-atlas-uri

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@travelexplore.com

# Security
# Set this to your Vercel deployment URL (e.g., https://your-app.vercel.app)
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your-session-secret-key

# File Upload (Note: Vercel filesystem is read-only. Use S3 or similar for persistence)
MAX_FILE_SIZE=5242880
UPLOAD_PATH=/tmp/uploads

# Google OAuth (if used)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-app.vercel.app/auth/google/callback

# External APIs
PAYMENT_GATEWAY_KEY=your-payment-gateway-key
MAP_API_KEY=your-google-maps-api-key
WEATHER_API_KEY=your-weather-api-key

# Admin Configuration
ADMIN_EMAIL=admin@travelexplore.com
ADMIN_PASSWORD=change-this-password